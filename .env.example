# Copiar a .env y ajustar si hace falta: cp .env.example .env

WEB_PORT=8080
MYSQL_PORT=3306

APP_BASE_URL=http://localhost:8080/
APP_INDEX_PAGE=

MYSQL_ROOT_PASSWORD=root_dev
MYSQL_DATABASE=crei_integracion
MYSQL_USER=crei
MYSQL_PASSWORD=crei_dev

# Backup diario (scripts/backup-database.sh)
# Carpeta fuera del webroot; el cron debe poder escribir ahí.
BACKUP_DIR=/var/backups/crei
# BACKUP_LOG=/ruta/al/proyecto/scripts/backup.log
BACKUP_RETENTION_DAYS=14
MYSQL_CONTAINER=crei-mysql
